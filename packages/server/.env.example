# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=sqlite:./data/simplicity.db

# Cache
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=*

# FFmpeg Paths (optional, system PATH used if not set)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# File Upload
MAX_FILE_SIZE=5368709120

# Export Settings
EXPORT_WORKERS=2
EXPORT_TIMEOUT=3600000
